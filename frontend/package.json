{
  "name": "tellmom-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "generate-api": "npx openapi-generator-cli generate -i http://localhost:8000/openapi.json -o ./src/apis -g typescript-fetch && find src/apis -name '*.ts' ! -name 'client.ts' -exec sh -c 'grep -q \"@ts-nocheck\" \"$1\" || sed -i \"1i// @ts-nocheck\" \"$1\"' _ {} \\;"
  },
  "dependencies": {
    "@openapitools/openapi-generator-cli": "^2.39.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.23.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.5.2",
    "openapi-typescript-codegen": "^0.29.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
